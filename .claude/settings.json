{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "3600000",
    "BASH_MAX_TIMEOUT_MS": "3600000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Search",
      "WebSearch",
      "Write(/tmp/*)",
      "Fetch(docs.rs)",
      "Fetch(*)"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.sui)",
      "Read(~/.gnupg)",
      "Read(~/.password-store)"
    ],
    "defaultMode": "default",
    "disableAutoMode": "disable"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "shellsafety"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-notify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-notify"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-resume"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-claude-cleanup"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh",
    "bgIsolation": "none"
  },
  "statusLine": {
    "type": "command",
    "command": "statusline",
    "padding": 2
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "showClearContextOnPlanAccept": true,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "verbose": false,
  "preferredNotifChannel": "notifications_disabled",
  "autoCompactEnabled": false,
  "fileCheckpointingEnabled": false,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false,
  "useAutoModeDuringPlan": false,
  "voiceEnabled": true,
  "autoMemory": false,
  "feedbackSurveyState": {
    "lastShownTime": 1855530480555
  }
}
